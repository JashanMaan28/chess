{
  "name": "chess-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --filter @chess/web dev",
    "dev:worker": "bun --filter @chess/worker dev",
    "build": "bun --filter '*' run build",
    "lint": "bun --filter '*' run lint",
    "typecheck": "bun --filter '*' run typecheck",
    "deploy:worker": "bun --filter @chess/worker deploy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3",
    "wrangler": "^4.90.0"
  },
  "module": "index.ts",
  "type": "module"
}
